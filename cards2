<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Notion Card Tool v1.4</title>
    <style>
        body { font-family: -apple-system, system-ui, sans-serif; background: #f7f7f5; margin: 0; padding: 0; }
        .builder-ui { padding: 40px 20px; text-align: center; display: block; }
        .box { background: white; padding: 30px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); display: inline-block; border: 1px solid #eee; width: 90%; max-width: 450px; }
        input { padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; width: 100%; box-sizing: border-box; margin-bottom: 10px; }
        button { padding: 12px; background: #000; color: #fff; border: none; border-radius: 8px; cursor: pointer; font-weight: 600; width: 100%; }
        #copyBtn { background: #007bff; display: none; margin-top: 10px; }
        #res { margin-top: 15px; font-size: 11px; color: #666; word-break: break-all; display: none; border: 1px dashed #ccc; padding: 10px; background: #f9f9f9; }

        /* Layout Notion - Ajustado para eliminar espaço vazio */
        .container { display: flex; gap: 12px; padding: 10px; display: none; justify-content: center; align-items: flex-start; }
        .card { 
            flex: 1; max-width: 50%; background: #fff; border: 1px solid #e9e9e8; border-radius: 10px; 
            text-decoration: none; color: inherit; display: flex; flex-direction: column; overflow: hidden;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }
        /* Altura fixa para a imagem não "esticar" */
        .image { width: 100%; height: 120px; background-size: cover; background-position: center; background-color: #eee; flex-shrink: 0; }
        /* Padding ajustado para o texto ficar próximo à imagem */
        .content { padding: 10px 12px 14px 12px; display: flex; flex-direction: column; }
        .title { font-weight: 700; font-size: 13px; margin-bottom: 4px; color: #111; line-height: 1.2; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .desc { font-size: 11px; color: #666; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    </style>
</head>
<body>

<div id="builder" class="builder-ui">
    <div class="box">
        <h2>Card Generator v1.4</h2>
        <input type="text" id="l1" placeholder="Link da Esquerda">
        <input type="text" id="l2" placeholder="Link da Direita">
        <button onclick="gerar()">Gerar Link</button>
        <div id="res"></div>
        <button id="copyBtn" onclick="copiar()">Copiar Link</button>
    </div>
</div>

<div id="display" class="container"></div>

<script>
    function getParam(name) {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get(name);
    }

    const link1 = getParam('l1');
    const link2 = getParam('l2');

    if (link1 || link2) {
        document.getElementById('builder').style.display = 'none';
        document.getElementById('display').style.display = 'flex';
        document.body.style.background = "transparent";
        if(link1) renderCard(link1);
        if(link2) renderCard(link2);
    }

    function renderCard(url) {
        fetch(`https://api.microlink.io?url=${encodeURIComponent(url)}`)
            .then(r => r.json()).then(res => {
                const d = res.data;
                const cardHtml = `
                    <a class="card" href="${url}" target="_blank">
                        <div class="image" style="background-image: url('${d.image?.url || ''}')"></div>
                        <div class="content">
                            <div class="title">${d.title || 'Link'}</div>
                            <div class="desc">${d.description || ''}</div>
                        </div>
                    </a>`;
                document.getElementById('display').innerHTML += cardHtml;
            });
    }

    function gerar() {
        const baseUrl = window.location.origin + window.location.pathname;
        const finalUrl = baseUrl + "?l1=" + encodeURIComponent(document.getElementById('l1').value.trim()) + "&l2=" + encodeURIComponent(document.getElementById('l2').value.trim());
        document.getElementById('res').innerText = finalUrl;
        document.getElementById('res').style.display = 'block';
        document.getElementById('copyBtn').style.display = 'block';
    }

    function copiar() {
        navigator.clipboard.writeText(document.getElementById('res').innerText).then(() => {
            document.getElementById('copyBtn').innerText = "✅ Copiado!";
        });
    }
</script>
</body>
</html>
